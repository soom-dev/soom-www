---
const installCommand = 'npx hansoom render diagram.mmd';

const audiences = [
  'Backend Engineers',
  'DevOps / SRE',
  'Technical Writers',
  'Solution Architects',
  'Educators',
  'Open-Source Maintainers',
];

const utm = (medium: string) =>
  `?utm_source=hansoom_dev&utm_medium=${medium}&utm_campaign=launch`;
---

<section class="pitch">
  <div class="pitch-inner">
    <h2 class="pitch-headline">
      Animate your Mermaid flowcharts<br />and architecture diagrams.
    </h2>

    <div class="install-block">
      <div class="install-label">Get started in one command</div>
      <div class="install-code">
        <code>{installCommand}</code>
        <button
          class="copy-btn"
          data-copy={installCommand}
          aria-label="Copy install command"
          type="button"
        >
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <rect
              x="5"
              y="5"
              width="9"
              height="9"
              rx="2"
              stroke="currentColor"
              stroke-width="1.5"></rect>
            <path
              d="M11 5V3.5A1.5 1.5 0 0 0 9.5 2h-6A1.5 1.5 0 0 0 2 3.5v6A1.5 1.5 0 0 0 3.5 11H5"
              stroke="currentColor"
              stroke-width="1.5"></path>
          </svg>
        </button>
      </div>
    </div>

    <div class="tiles">
      <a
        class="tile"
        href={`https://github.com/soom-dev/soom${utm('tile_stars')}`}
        target="_blank"
        rel="noopener noreferrer"
      >
        <span class="tile-icon">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path
              d="M10 1.5l2.47 5.01 5.53.8-4 3.9.94 5.49L10 14.26 5.06 16.7 6 11.21l-4-3.9 5.53-.8z"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linejoin="round"></path>
          </svg>
        </span>
        <span class="tile-label">Star on GitHub</span>
      </a>

      <a
        class="tile"
        href={`https://www.npmjs.com/package/hansoom${utm('tile_npm')}`}
        target="_blank"
        rel="noopener noreferrer"
      >
        <span class="tile-icon">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <rect
              x="2"
              y="2"
              width="16"
              height="16"
              rx="2"
              stroke="currentColor"
              stroke-width="1.5"></rect>
            <path d="M6 14V6h4v8M10 6h4v5h-2" stroke="currentColor" stroke-width="1.5"
            ></path>
          </svg>
        </span>
        <span class="tile-label">npm package</span>
      </a>

      <a
        class="tile tile-accent"
        href={`https://hansoom.dev/play${utm('tile_try')}`}
      >
        <span class="tile-icon">▶</span>
        <span class="tile-label">Try it live</span>
      </a>
    </div>

    <div class="comparison">
      <h3>Before & After</h3>
      <div class="comparison-row">
        <div class="comparison-card">
          <div class="comparison-header">Static Mermaid</div>
          <div class="comparison-body comparison-static">
            <svg viewBox="0 0 300 80" class="comparison-svg">
              <rect
                x="10"
                y="18"
                width="80"
                height="44"
                rx="6"
                fill="none"
                stroke="#888"
                stroke-width="1.5"
                opacity="0.5"></rect>
              <text x="50" y="44" text-anchor="middle" fill="#888" font-size="12"
                >Start</text
              >
              <line
                x1="90"
                y1="40"
                x2="120"
                y2="40"
                stroke="#888"
                stroke-width="1.5"
                opacity="0.4"></line>
              <rect
                x="120"
                y="18"
                width="80"
                height="44"
                rx="6"
                fill="none"
                stroke="#888"
                stroke-width="1.5"
                opacity="0.5"></rect>
              <text x="160" y="44" text-anchor="middle" fill="#888" font-size="12"
                >Process</text
              >
              <line
                x1="200"
                y1="40"
                x2="230"
                y2="40"
                stroke="#888"
                stroke-width="1.5"
                opacity="0.4"></line>
              <rect
                x="230"
                y="18"
                width="60"
                height="44"
                rx="6"
                fill="none"
                stroke="#888"
                stroke-width="1.5"
                opacity="0.5"></rect>
              <text x="260" y="44" text-anchor="middle" fill="#888" font-size="12"
                >End</text
              >
            </svg>
          </div>
        </div>

        <div class="comparison-arrow">→</div>

        <div class="comparison-card comparison-card-active">
          <div class="comparison-header">With Hansoom</div>
          <div class="comparison-body comparison-animated">
            <svg viewBox="0 0 300 80" class="comparison-svg">
              <rect
                x="10"
                y="18"
                width="80"
                height="44"
                rx="6"
                fill="var(--soom-completed-fill)"
                stroke="var(--soom-completed-fill)"
                stroke-width="1.5"
                opacity="0.85"></rect>
              <text
                x="50"
                y="44"
                text-anchor="middle"
                fill="var(--soom-bg)"
                font-size="12"
                font-weight="700">Start</text
              >
              <line
                x1="90"
                y1="40"
                x2="120"
                y2="40"
                stroke="var(--soom-edge-stroke-active)"
                stroke-width="2"></line>
              <rect
                x="120"
                y="18"
                width="80"
                height="44"
                rx="6"
                fill="var(--soom-accent)"
                stroke="var(--soom-accent)"
                stroke-width="1.5"
                class="pulse-node"></rect>
              <text
                x="160"
                y="44"
                text-anchor="middle"
                fill="#fff"
                font-size="12"
                font-weight="700">Process</text
              >
              <line
                x1="200"
                y1="40"
                x2="230"
                y2="40"
                stroke="var(--soom-edge-stroke-rest)"
                stroke-width="1.5"
                opacity="0.5"></line>
              <rect
                x="230"
                y="18"
                width="60"
                height="44"
                rx="6"
                fill="none"
                stroke="var(--soom-edge-stroke-rest)"
                stroke-width="1.5"
                opacity="0.4"></rect>
              <text
                x="260"
                y="44"
                text-anchor="middle"
                fill="var(--soom-text)"
                font-size="12"
                opacity="0.4">End</text
              >
            </svg>
          </div>
        </div>
      </div>
    </div>

    <div class="audiences">
      <h3>Built for</h3>
      <div class="audience-chips">
        {audiences.map((a) => <span class="chip">{a}</span>)}
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const text = (btn as HTMLElement).dataset.copy || '';
      navigator.clipboard.writeText(text).then(() => {
        const el = btn as HTMLElement;
        el.classList.add('copied');
        setTimeout(() => el.classList.remove('copied'), 1500);
      });
    });
  });
</script>

<style>
  .pitch {
    padding: 80px 0;
  }

  .pitch-inner {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 var(--soom-space-xxl);
  }

  .pitch-headline {
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 700;
    text-align: center;
    color: var(--soom-text);
    line-height: 1.3;
    margin-bottom: 48px;
  }

  .install-block {
    text-align: center;
    margin-bottom: 48px;
  }

  .install-label {
    font-size: 0.9rem;
    color: var(--soom-text-muted);
    margin-bottom: var(--soom-space-sm);
  }

  .install-code {
    display: inline-flex;
    align-items: center;
    gap: var(--soom-space-sm);
    background: var(--soom-controls-bg);
    padding: var(--soom-space-md) var(--soom-space-xl);
    border-radius: var(--soom-rounded-sm);
    border: 1px solid var(--soom-edge-stroke-rest);
  }

  .install-code code {
    font-size: 1rem;
    background: none;
    padding: 0;
    color: var(--soom-accent);
  }

  .copy-btn {
    background: none;
    border: none;
    color: var(--soom-text-muted);
    cursor: pointer;
    padding: 4px;
    border-radius: 4px;
    display: flex;
    align-items: center;
    transition: color 0.2s;
  }

  .copy-btn:hover {
    color: var(--soom-text);
  }

  .copy-btn.copied {
    color: var(--soom-accent);
  }

  .tiles {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--soom-space-lg);
    margin-bottom: 64px;
  }

  .tile {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--soom-space-sm);
    padding: var(--soom-space-xl) var(--soom-space-lg);
    background: var(--soom-controls-bg);
    border-radius: var(--soom-rounded-md);
    border: 1px solid var(--soom-edge-stroke-rest);
    color: var(--soom-text);
    text-decoration: none;
    transition:
      border-color 0.2s,
      transform 0.2s;
  }

  .tile:hover {
    border-color: var(--soom-accent);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .tile-accent {
    background: var(--soom-accent);
    border-color: var(--soom-accent);
    color: #fff;
  }

  .tile-accent:hover {
    border-color: var(--soom-accent);
    opacity: 0.9;
  }

  .tile-icon {
    font-size: 1.5rem;
    color: var(--soom-text-muted);
  }

  .tile-accent .tile-icon {
    color: #fff;
  }

  .tile-label {
    font-size: 0.95rem;
    font-weight: 600;
  }

  .comparison {
    margin-bottom: 64px;
  }

  .comparison h3 {
    text-align: center;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--soom-text);
    margin-bottom: var(--soom-space-xl);
  }

  .comparison-row {
    display: flex;
    align-items: center;
    gap: var(--soom-space-xl);
  }

  .comparison-card {
    flex: 1;
    border-radius: var(--soom-rounded-md);
    border: 1px solid var(--soom-edge-stroke-rest);
    overflow: hidden;
  }

  .comparison-card-active {
    border-color: var(--soom-accent);
  }

  .comparison-header {
    padding: var(--soom-space-sm) var(--soom-space-lg);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--soom-text-muted);
    background: var(--soom-controls-bg);
    border-bottom: 1px solid var(--soom-edge-stroke-rest);
  }

  .comparison-card-active .comparison-header {
    color: var(--soom-accent);
    border-bottom-color: var(--soom-accent);
  }

  .comparison-body {
    padding: var(--soom-space-xl);
    background: var(--soom-bg);
  }

  .comparison-static {
    filter: grayscale(1);
    opacity: 0.6;
  }

  .comparison-animated {
    background-image: radial-gradient(
      var(--soom-grid-dot) 1px,
      transparent 1px
    );
    background-size: 24px 24px;
  }

  .comparison-svg {
    width: 100%;
    height: auto;
  }

  .comparison-arrow {
    font-size: 1.5rem;
    color: var(--soom-text-muted);
    flex-shrink: 0;
  }

  @keyframes pulse {
    0%,
    100% {
      filter: drop-shadow(-6px 10px 16px var(--soom-shadow-active));
    }
    50% {
      filter: drop-shadow(-6px 10px 20px var(--soom-accent-glow));
    }
  }

  .pulse-node {
    animation: pulse 2s infinite ease-in-out;
  }

  .audiences {
    text-align: center;
  }

  .audiences h3 {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--soom-text);
    margin-bottom: var(--soom-space-lg);
  }

  .audience-chips {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--soom-space-sm);
  }

  .chip {
    padding: var(--soom-space-xs) var(--soom-space-lg);
    border-radius: var(--soom-rounded-pill);
    background: var(--soom-controls-bg);
    border: 1px solid var(--soom-edge-stroke-rest);
    color: var(--soom-text-muted);
    font-size: 0.85rem;
    font-weight: 500;
  }

  @media (max-width: 640px) {
    .tiles {
      grid-template-columns: 1fr;
    }

    .comparison-row {
      flex-direction: column;
    }

    .comparison-arrow {
      transform: rotate(90deg);
    }
  }

  @media (max-width: 480px) {
    .pitch-inner {
      padding: 0 var(--soom-space-lg);
    }

    .install-code {
      padding: var(--soom-space-sm) var(--soom-space-lg);
    }

    .install-code code {
      font-size: 0.85rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tile {
      transition: none;
    }

    .pulse-node {
      animation: none;
      filter: drop-shadow(-6px 10px 16px var(--soom-shadow-active));
    }
  }
</style>
